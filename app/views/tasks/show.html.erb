<div class="max-w-2xl mx-auto">
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-800">Task Details</h1>
    <%= link_to "← Back to Tasks", tasks_path, class: "text-indigo-600 hover:text-indigo-800 text-sm font-medium" %>
  </div>

  <div class="bg-white shadow-sm rounded-xl border border-gray-100 p-8 space-y-5">
    <div>
      <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Title</label>
      <p class="mt-1 text-lg font-semibold text-gray-800"><%= @task.title %></p>
    </div>

    <% if @task.description.present? %>
      <div>
        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Description</label>
        <p class="mt-1 text-gray-700 text-sm leading-relaxed"><%= @task.description %></p>
      </div>
    <% end %>

    <div class="grid grid-cols-3 gap-6">
      <div>
        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Status</label>
        <% badge_class = case @task.status
          when "pending" then "bg-yellow-100 text-yellow-800"
          when "in_progress" then "bg-blue-100 text-blue-800"
          when "completed" then "bg-green-100 text-green-800"
          else "bg-gray-100 text-gray-800"
        end %>
        <div class="mt-2">
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold <%= badge_class %>">
            <%= @task.status.humanize %>
          </span>
        </div>
      </div>
      <div>
        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Due Date</label>
        <p class="mt-1 text-sm text-gray-700"><%= @task.due_date&.strftime("%B %d, %Y") || "Not set" %></p>
      </div>
      <div>
        <label class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Created</label>
        <p class="mt-1 text-sm text-gray-700"><%= @task.created_at.strftime("%B %d, %Y") %></p>
      </div>
    </div>

    <div class="pt-4 border-t border-gray-100 flex items-center space-x-3">
      <%= link_to "Edit Task", edit_task_path(@task), class: "bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2 rounded-lg text-sm font-semibold transition" %>
      <%= button_to "Delete Task", task_path(@task), method: :delete,
          class: "bg-red-50 hover:bg-red-100 text-red-600 px-5 py-2 rounded-lg text-sm font-semibold transition border border-red-100",
          data: { turbo_confirm: "Are you sure you want to delete this task?" } %>
    </div>
  </div>
</div>
