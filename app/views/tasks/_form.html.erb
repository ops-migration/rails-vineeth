<div class="bg-white shadow-sm rounded-xl border border-gray-100 max-w-2xl mx-auto p-8">
  <%= form_with(model: @task, class: "space-y-6") do |f| %>
    <% if @task.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <div class="flex items-start space-x-3">
          <svg class="h-5 w-5 text-red-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
          <div>
            <h3 class="text-sm font-semibold text-red-800"><%= @task.errors.count %> error(s) prevented this task from being saved:</h3>
            <ul class="mt-2 list-disc list-inside space-y-1">
              <% @task.errors.full_messages.each do |message| %>
                <li class="text-sm text-red-700"><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div>
      <%= f.label :title, "Title", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
      <%= f.text_field :title, placeholder: "What needs to be done?",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
    </div>

    <div>
      <%= f.label :description, "Description", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
      <%= f.text_area :description, rows: 4, placeholder: "Optional details about this task…",
          class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition resize-none" %>
    </div>

    <div class="grid grid-cols-2 gap-6">
      <div>
        <%= f.label :status, "Status", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.select :status,
            [["Pending", "pending"], ["In Progress", "in_progress"], ["Completed", "completed"]],
            {},
            class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition bg-white" %>
      </div>

      <div>
        <%= f.label :due_date, "Due Date", class: "block text-sm font-semibold text-gray-700 mb-1.5" %>
        <%= f.date_field :due_date,
            class: "w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" %>
      </div>
    </div>

    <div class="flex items-center justify-between pt-2">
      <%= link_to "Cancel", tasks_path, class: "text-sm text-gray-500 hover:text-gray-700 font-medium" %>
      <%= f.submit @task.new_record? ? "Create Task" : "Update Task",
          class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-lg text-sm font-semibold transition cursor-pointer" %>
    </div>
  <% end %>
</div>
